{
  "name": "react-router-antd-admin",
  "version": "0.2.0",
  "description": "React Router Antd Admin",
  "type": "module",
  "keywords": [
    "React Router",
    "antd",
    "tailwindcss",
    "hono",
    "admin",
    "postresql",
    "langchain",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yyong008/remix-antd-admin.git"
  },
  "homepage": "https://remix-antd-admin.vercel.app/",
  "author": {
    "name": "yong",
    "email": "yyong008@outlook.com",
    "url": "https://github.com/yyong008"
  },
  "license": "MIT",
  "scripts": {
    "build": "react-router build",
    "coverage": "vp test run --coverage",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "biome lint .",
    "clean": "rimraf ./node_modules",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vp test",
    "typecheck": "react-router typegen && tsc",
    "commit": "git-cz",
    "changeset": "changeset",
    "version": "changeset version",
    "prepare": "husky install",
    "docker:build": "docker build -t remix-antd-admin .",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:migrate": "drizzle-kit migrate",
    "postinstall": "fumadocs-mdx",
    "db:seed": "dotenv -c -e ./.env  tsx db/seed.ts"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.1.1",
    "@ant-design/pro-chat": "^1.15.3",
    "@ant-design/pro-components": "^2.8.10",
    "@ant-design/pro-editor": "^1.3.0",
    "@ant-design/x": "^2.5.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/react": "^1.22.0",
    "@inlang/paraglide-js": "^2.16.0",
    "@js-temporal/polyfill": "^0.4.4",
    "@langchain/core": "^0.3.80",
    "@langchain/ollama": "^0.1.6",
    "@marsidev/react-turnstile": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@orama/tokenizers": "^3.1.18",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@tanstack/react-query": "^5.99.2",
    "ai": "^6.0.168",
    "antd": "^6.3.6",
    "antd-style": "^3.7.1",
    "better-auth": "^1.6.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.0",
    "dotenv": "^17.4.2",
    "drizzle": "^1.4.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fumadocs-core": "^16.8.0",
    "fumadocs-mdx": "^14.3.1",
    "fumadocs-ui": "^16.8.0",
    "hono": "^4.12.14",
    "is-ip": "^5.0.1",
    "isbot": "^5.1.39",
    "jose": "^5.10.0",
    "js-export-excel": "^1.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.14.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "nprogress": "^0.2.0",
    "ollama": "^0.5.18",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "quill": "^2.0.3",
    "react": "^19.2.5",
    "react-advanced-cropper": "^0.19.6",
    "react-dom": "^19.2.5",
    "react-image-crop": "^11.0.10",
    "react-intersection-observer": "^9.16.0",
    "react-quill": "^2.0.0",
    "react-router": "^7.14.1",
    "react-type-animation": "^3.2.0",
    "remix-utils": "^9.3.1",
    "resend": "^6.12.0",
    "tailwind-merge": "^3.5.0",
